# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App
NEXT_PUBLIC_APP_URL=https://icut.pk
NEXT_PUBLIC_APP_NAME=iCut
NEXT_PUBLIC_DEMO_MODE=false

# Security (required for production — server actions use these)
SESSION_SECRET=generate-with-openssl-rand-hex-32
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (for transactional emails — optional at launch)
# EMAIL_FROM=hello@icut.pk
# RESEND_API_KEY=your-resend-key

# Super Admin (comma-separated emails with platform-level access)
# SUPERADMIN_EMAILS=admin@icut.pk

# Support (used in email templates and contact page)
# SUPPORT_WHATSAPP=923001234567
# SUPPORT_EMAIL=support@icut.pk

# Mapbox (marketplace — browser maps + server-side geocoding)
# NEXT_PUBLIC_MAPBOX_TOKEN is exposed to the browser for the map component.
# URL-restrict it in the Mapbox dashboard to icut.pk domains to prevent abuse.
NEXT_PUBLIC_MAPBOX_TOKEN=
# MAPBOX_GEOCODING_TOKEN is server-only, used by src/lib/mapbox.ts for
# forward/reverse geocoding. Scope it to geocoding only in the Mapbox dashboard.
# Free tier allows 100K geocoding requests/month.
MAPBOX_GEOCODING_TOKEN=
